{
  "name": "sekimori",
  "version": "0.2.0",
  "type": "module",
  "description": "A minimal self-hosted gateway for shipping AI prototypes without exposing your API key, melting your budget, or becoming a free LLM proxy.",
  "keywords": [
    "anthropic",
    "claude",
    "llm",
    "gateway",
    "proxy",
    "api-key",
    "rate-limiting",
    "budget",
    "self-hosted",
    "hono"
  ],
  "homepage": "https://github.com/yktsnd/sekimori#readme",
  "bugs": {
    "url": "https://github.com/yktsnd/sekimori/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yktsnd/sekimori.git"
  },
  "license": "MIT",
  "bin": {
    "sekimori": "dist/main.js"
  },
  "files": [
    "dist",
    "docs",
    "!docs/history",
    "examples",
    "sekimori.config.example.json",
    "README.md",
    "README.ja.md",
    "AGENTS.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "SUPPORT.md",
    "GOVERNANCE.md",
    "CODE_OF_CONDUCT.md",
    "RELEASING.md",
    "ROADMAP.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "node scripts/build.mjs",
    "prepack": "node scripts/build.mjs",
    "test": "node scripts/run-tests.mjs",
    "demo": "node examples/demo.mjs",
    "test:pack": "node test/pack-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "release:check": "node scripts/release-check.mjs",
    "prepublishOnly": "npm run release:check && npm run typecheck && npm test && npm run demo && npm run test:pack"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
